# ClubBot environment variables
# Copy this file to `.env` and fill in your own values.
# None of these are committed to source control.

# Discord bot token — from the Discord Developer Portal
# (Applications > your app > Bot > Reset Token)
DISCORD_TOKEN=

# Discord application (client) ID — from the same app's "General Information" page
APP_ID=

# TheTVDB v4 API token — used for movie lookups
# https://thetvdb.com/api-information
TVDB_TOKEN=

# Google Books API key — used for book lookups
# https://console.cloud.google.com (enable the Books API, then create an API key)
GOOGLE_BOOKS_TOKEN=
